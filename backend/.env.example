# Copy to .env and fill in real values. Never commit .env.

# Groq API key (free at https://console.groq.com -> API Keys)
GROQ_API_KEY=gsk_your_key_here

# Groq model: gemma2-9b-it (primary) or llama-3.3-70b-versatile (alternative)
GROQ_MODEL=gemma2-9b-it

# PostgreSQL connection
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aivoa_crm

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
