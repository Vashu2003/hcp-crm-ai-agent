# Copy to .env and fill in real values. Never commit .env.

# Groq API key (free at https://console.groq.com -> API Keys)
GROQ_API_KEY=gsk_your_key_here

# Groq model (configurable). NOTE: the assignment's primary (gemma2-9b-it) was
# decommissioned by Groq. Default below is a light gemma-class model that fits the
# free-tier daily token budget. For higher quality use the assignment's listed
# alternative: GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# PostgreSQL connection
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aivoa_crm

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
